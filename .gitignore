# ==============================================================
# SignalBridge .gitignore (Unity / Windows + Mac 両対応)
# ==============================================================

# --- Unity 生成フォルダ ---
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# --- Asset meta data (ディレクトリ削除時に残る空 meta のみ無視) ---
/[Aa]ssets/**/*.meta.orig

# --- IDE / プロジェクトファイル (自動生成) ---
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# --- Rider / Visual Studio / VS Code ---
.idea/
.vs/
.vscode/

# --- Gradle (Android ビルド) ---
ExportedObj/
.gradle/

# --- crashlogs ---
sysinfo.txt
crashlog*.txt

# --- Unity プロファイラ / プロファイル キャプチャ ---
/[Pp]rofilerCaptures/

# --- ビルド成果物 ---
*.apk
*.aab
*.unitypackage
*.app

# --- Claude Code (ローカル設定) ---
.claude/

# --- Python (Phase 0 検証ツール tools/ 用) ---
# venv 本体はコミットしない (再現は tools/requirements.txt から). スクリプト自体は追跡する.
tools/.venv/
__pycache__/
*.pyc

# --- OS 生成ファイル ---
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
