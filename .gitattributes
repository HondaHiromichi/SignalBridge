# ==============================================================
# SignalBridge .gitattributes (Windows + Mac 両対応)
# 改行コードを正規化し, OS 間で不要な全行差分が出ないようにする.
# ==============================================================

# 既定: テキストは自動判別し, リポジトリ内では LF に正規化 (チェックアウトは OS ネイティブ)
* text=auto

# --- ソース / テキスト (LF に固定) ---
*.cs        text eol=lf diff=csharp
*.shader    text eol=lf
*.cginc     text eol=lf
*.hlsl      text eol=lf
*.compute   text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.xml       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# --- Unity テキストアセット (JSON/レイアウト等) ---
*.inputactions text eol=lf
*.wlt          text eol=lf
*.asmdef       text eol=lf
*.asmref       text eol=lf

# --- OS 固有スクリプト ---
*.sh        text eol=lf
*.py        text eol=lf
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# --- Unity YAML ファイル: 専用マージドライバ unityyamlmerge を使用 ---
# (各環境で `git config merge.unityyamlmerge.driver` を設定すると有効. 未設定でも通常マージに fallback)
*.meta            merge=unityyamlmerge eol=lf
*.unity           merge=unityyamlmerge eol=lf
*.asset           merge=unityyamlmerge eol=lf
*.prefab          merge=unityyamlmerge eol=lf
*.mat             merge=unityyamlmerge eol=lf
*.controller      merge=unityyamlmerge eol=lf
*.anim            merge=unityyamlmerge eol=lf
*.physicMaterial  merge=unityyamlmerge eol=lf
*.physicsMaterial2D merge=unityyamlmerge eol=lf

# --- バイナリ (差分・改行変換を無効化) ---
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.psd  binary
*.tga  binary
*.tif  binary
*.tiff binary
*.bmp  binary
*.ico  binary
*.fbx  binary
*.obj  binary
*.blend binary
*.wav  binary
*.mp3  binary
*.ogg  binary
*.aif  binary
*.mp4  binary
*.mov  binary
*.unitypackage binary
*.dll  binary
*.so   binary
*.dylib binary
*.a    binary
*.bundle binary
*.ttf  binary
*.otf  binary
